# ── Application ──────────────────────────────────────────────
APP_NAME=AcadMind
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM (recommended: Gemini free tier for zero-budget MVP) ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Alternatives (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Embeddings (Phase 2 RAG) ─────────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-3-small

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=acadmind_dev_password

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Redis / Celery (Phase 5+) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Uploads (Phase 3+) ───────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── Auth (dev) ───────────────────────────────────────────────
# Creates confirmed accounts via admin API — no confirmation email sent.
AUTH_AUTO_CONFIRM_SIGNUP=true

# ── Logging / API gateway ────────────────────────────────────
LOG_LEVEL=INFO
LOG_GATEWAY_REQUESTS=true
GATEWAY_LOG_BUFFER_SIZE=200

# ── Demo / Jarvis ────────────────────────────────────────────
DEMO_SEED_ENABLED=true
JARVIS_USE_LLM=false
